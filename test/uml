package "10. Channel / Contract / Higher-Level Bitcoin-Native Protocols" {
  class PaymentChannel
  class LightningNetwork
  class CommitmentTx
  class HTLC
  class PTLC
  class ChannelFactory
  class Watchtower
  class DLC
  class OracleSignature
  class Ark
  class Fedimint
  class ChaumianEcash
  class CoinJoin
  class PayJoin
  class Statechain
  class Sidechain
  class DrivechainConcept
  class CovenantsResearch
}

package "11. Data / Indexing / Client Access Layer" {
  class RPC
  class ZMQ
  class Indexer
  class Explorer
  class ElectrumProtocol
  class NeutrinoClient
  class WalletAPI
  class BlockFilter
  class TxIndex
  class AddressIndex
}

package "12. Meta / Overlay / Application Layer" {
  class Timestamping
  class ProofOfReserves
  class OpenAssetsLikeProtocols
  class ColoredCoins
  class Ordinals
  class Inscriptions
  class Runes
  class RGB
  class NostrAnchoring
  class ExternalRollupAnchors
  class MergeMinedOverlay
  class KapnetLikeOverlay
}

' Foundations
DoubleSHA256 --> SHA256
DigitalSignature --> Secp256k1
ECDSA --> Secp256k1
Schnorr --> Secp256k1
MerkleTree --> DoubleSHA256
ProofOfWork --> DoubleSHA256
ProofOfWork --> DifficultyRetarget
TimelockMath --> Locktime
TimelockMath --> Sequence

' Ledger composition
Block --> BlockHeader
Block --> Transaction
Transaction --> TxInput
Transaction --> TxOutput
TxInput --> OutPoint
TxInput --> ScriptSig
TxInput --> WitnessStack
TxOutput --> ScriptPubKey
UTXO --> TxOutput
CoinbaseTx --|> Transaction

' Script layer
ScriptVM --> Script
ScriptVM --> Stack
ScriptVM --> Opcodes
P2PKH --> ScriptPubKey
P2SH --> ScriptPubKey
BareMultisig --> ScriptPubKey
OP_RETURN --> ScriptPubKey
CLTV --> Opcodes
CSV --> Opcodes
SegWitV0 --> WitnessStack
Taproot --> XOnlyPubKey
Taproot --> Tapscript
Tapscript --> ScriptPathSpend
Taproot --> KeyPathSpend
Taproot --> ControlBlock
MAST --> MerkleTree

' Encodings and wallet
Base58Check --> P2PKH
Base58Check --> P2SH
Bech32 --> SegWitV0
Bech32m --> Taproot
Descriptor --> ScriptPubKey
Descriptor --> Miniscript
HDWallet --> Wallet
HDWallet --> MasterKey
MasterKey --> BIP39Seed
SeedPhrase --> BIP39Seed
ExtendedPubKey --> BIP32Path
ExtendedPrivKey --> BIP32Path
PSBT --> Transaction
PSBT --> Signer
HardwareWallet --> Signer
Wallet --> CoinSelection
Wallet --> ChangeOutput
Wallet --> SpendingPolicy
OutputDescriptorWallet --> Descriptor
WatchOnlyWallet --> Descriptor

' Node / validation
FullNode --> TxValidation
FullNode --> BlockValidation
FullNode --> UTXOSet
FullNode --> Chainstate
PrunedNode --|> FullNode
ArchivalNode --|> FullNode
MiningNode --|> FullNode
ConsensusRules --> BlockValidation
ConsensusRules --> TxValidation
StandardnessRules --> RelayPolicy
Mempool --> FeeRate
Mempool --> VirtualBytes
WeightUnits --> VirtualBytes
FullNode --> Reorg
FullNode --> FeeEstimation
FullNode --> MempoolPolicy

' P2P
FullNode --> Peer
Peer --> P2PTransport
VersionHandshake --> Peer
PeerDiscovery --> DNSSeeds
Peer --> AddrMessages
Peer --> InvMessages
Peer --> GetDataMessages
TxRelay --> Transaction
BlockRelay --> Block
HeaderRelay --> BlockHeader
BIP324Transport --> EncryptionSession
TorI2P --> Peer

' Mining / issuance
Miner --> MiningTemplate
MiningTemplate --> BlockAssembler
BlockAssembler --> Transaction
BlockAssembler --> CoinbaseTx
CoinbaseCommitments --> CoinbaseTx
Subsidy --> CoinbaseTx
Fees --> CoinbaseTx
Halving --> Subsidy
DifficultyEpoch --> DifficultyRetarget
Target --> BlockHeader
NonceSearch --> BlockHeader
ExtraNonce --> CoinbaseTx
Pool --> Stratum
Stratum --> Miner

' Timechain transitions
GenesisBlock --> Block
BestChain --> ChainTip
Fork --> ChainTip
SoftFork --> Activation
SoftFork --> ConsensusRules
HardFork --> ConsensusRules
VersionBits --> Activation
BuriedDeployment --> Activation
UASF --> Activation

' BIPs / sub-protocols
BIP16_P2SH --> P2SH
BIP32_HD --> HDWallet
BIP39_Mnemonic --> SeedPhrase
BIP43_Purpose --> BIP32Path
BIP44_MultAccount --> Account
BIP65_CLTV --> CLTV
BIP68_Sequence --> Sequence
BIP112_CSV --> CSV
BIP141_SegWit --> SegWitV0
BIP143_SegWitDigest --> SegWitV0
BIP157_158_Neutrino --> BlockFilter
BIP173_Bech32 --> Bech32
BIP174_PSBT --> PSBT
BIP340_Schnorr --> Schnorr
BIP341_Taproot --> Taproot
BIP342_Tapscript --> Tapscript
BIP324_v2Transport --> BIP324Transport

' Higher-level protocols
PaymentChannel --> Transaction
LightningNetwork --> PaymentChannel
CommitmentTx --> Transaction
HTLC --> Script
PTLC --> Schnorr
Watchtower --> LightningNetwork
DLC --> OracleSignature
DLC --> Taproot
Ark --> Transaction
Fedimint --> ChaumianEcash
CoinJoin --> Transaction
PayJoin --> Transaction
Statechain --> Transaction
Sidechain --> BlockHeader
DrivechainConcept --> Sidechain
CovenantsResearch --> Script

' Data / access
RPC --> FullNode
ZMQ --> FullNode
Indexer --> Block
Indexer --> Transaction
Explorer --> Indexer
ElectrumProtocol --> Indexer
NeutrinoClient --> BlockFilter
WalletAPI --> Wallet
TxIndex --> Indexer
AddressIndex --> Indexer

' Overlays / application uses
Timestamping --> OP_RETURN
ProofOfReserves --> MerkleTree
ColoredCoins --> Transaction
OpenAssetsLikeProtocols --> ColoredCoins
Ordinals --> Transaction
Inscriptions --> WitnessStack
Runes --> Transaction
RGB --> Taproot
NostrAnchoring --> OP_RETURN
ExternalRollupAnchors --> Transaction
MergeMinedOverlay --> CoinbaseCommitments
KapnetLikeOverlay --> OP_RETURN
KapnetLikeOverlay --> MerkleTree
KapnetLikeOverlay --> Transaction

@enduml
