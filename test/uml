@startuml
title Bitcoin Primitives, Sub-Protocols, and Layers

skinparam backgroundColor white
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ArrowColor black
skinparam DefaultTextAlignment left

package "0. Mathematical / Cryptographic Foundations" {
  class SHA256
  class DoubleSHA256
  class RIPEMD160
  class Secp256k1
  class Schnorr
  class ECDSA
  class MerkleTree
  class HashPreimage
  class DigitalSignature
  class TimelockMath
  class DifficultyRetarget
  class ProofOfWork
}

package "1. Consensus-Native Ledger Primitives" {
  class BlockHeader {
    version
    prev_block
    merkle_root
    time
    nBits
    nonce
  }

  class Block {
    txs[]
    witness_commitment?
  }

  class Transaction {
    version
    vin[]
    vout[]
    locktime
  }

  class TxInput {
    prevout
    scriptSig
    sequence
    witness?
  }

  class TxOutput {
    value
    scriptPubKey
  }

  class OutPoint
  class UTXO
  class CoinbaseTx
  class ChainTip
  class Mempool
  class FeeRate
  class WeightUnits
  class VirtualBytes
  class Script
  class ScriptPubKey
  class ScriptSig
  class WitnessStack
  class Locktime
  class Sequence
  class MTP
}

package "2. Script / Spending Condition Layer" {
  class ScriptVM
  class Stack
  class Opcodes
  class P2PK
  class P2PKH
  class P2SH
  class BareMultisig
  class OP_RETURN
  class CLTV
  class CSV
  class SegWitV0
  class Taproot
  class Tapscript
  class KeyPathSpend
  class ScriptPathSpend
  class Annex
  class ControlBlock
  class MAST
}

package "3. Address / Commitment Encodings" {
  class Base58Check
  class Bech32
  class Bech32m
  class WIF
  class XOnlyPubKey
  class ExtendedPubKey
  class ExtendedPrivKey
  class BIP32Path
  class Descriptor
  class Miniscript
}

package "4. Wallet / Key Management / Policy Layer" {
  class Wallet
  class HDWallet
  class SeedPhrase
  class BIP39Seed
  class MasterKey
  class Account
  class CoinSelection
  class ChangeOutput
  class PSBT
  class Signer
  class HardwareWallet
  class OutputDescriptorWallet
  class WatchOnlyWallet
  class SpendingPolicy
}

package "5. Node / Validation / Relay Layer" {
  class FullNode
  class ArchivalNode
  class PrunedNode
  class MiningNode
  class RelayPolicy
  class ConsensusRules
  class StandardnessRules
  class BlockValidation
  class TxValidation
  class UTXOSet
  class Chainstate
  class Reorg
  class FeeEstimation
  class AddrRelay
  class InvGetData
  class HeadersFirstSync
  class CompactBlocks
  class MempoolPolicy
}

package "6. P2P Networking Layer" {
  class P2PTransport
  class VersionHandshake
  class Peer
  class PeerDiscovery
  class DNSSeeds
  class AddrMessages
  class InvMessages
  class GetDataMessages
  class TxRelay
  class BlockRelay
  class HeaderRelay
  class BIP324Transport
  class EncryptionSession
  class TorI2P
}

package "7. Mining / Time / Issuance Layer" {
  class Miner
  class MiningTemplate
  class BlockAssembler
  class CoinbaseCommitments
  class Subsidy
  class Fees
  class Halving
  class Timestamp
  class DifficultyEpoch
  class Target
  class NonceSearch
  class ExtraNonce
  class Stratum
  class Pool
}

package "8. Timechain State Transitions" {
  class GenesisBlock
  class BestChain
  class Fork
  class SoftFork
  class HardFork
  class Activation
  class BuriedDeployment
  class VersionBits
  class UASF
  class RollbackWindow
  class FinalityEconomic
}

package "9. Canonical Bitcoin Upgrade / Spec Sub-Protocols" {
  class BIP16_P2SH
  class BIP32_HD
  class BIP39_Mnemonic
  class BIP43_Purpose
  class BIP44_MultAccount
  class BIP65_CLTV
  class BIP68_Sequence
  class BIP112_CSV
  class BIP141_SegWit
  class BIP143_SegWitDigest
  class BIP157_158_Neutrino
